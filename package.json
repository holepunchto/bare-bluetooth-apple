{
  "name": "bare-bluetooth-apple",
  "version": "0.1.1",
  "description": "CoreBluetooth bindings for Bare",
  "exports": {
    "./package": "./package.json",
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "binding.mm",
    "binding.js",
    "CMakeLists.txt",
    "lib",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "brittle-bare --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/bare-bluetooth-apple.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/bare-bluetooth-apple/issues"
  },
  "homepage": "https://github.com/holepunchto/bare-bluetooth-apple#readme",
  "dependencies": {
    "bare-events": "^2.8.2",
    "bare-stream": "^2.11.0"
  },
  "devDependencies": {
    "bare-encoding": "^1.0.3",
    "bare-os": "^3.7.1",
    "brittle": "^3.18.0",
    "cmake-bare": "^1.6.5",
    "cmake-fetch": "^1.4.9",
    "cmake-harden": "^1.1.2",
    "lunte": "^1.6.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0"
  }
}
